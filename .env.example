# API auth for protected HTTP endpoints
MAGICLAW_API_TOKEN=change_me

# Primary Feishu account (maps to channel id: feishu when account_id=default)
MAGICLAW_FEISHU_ENABLED=true
MAGICLAW_FEISHU_ACCOUNT_ID=default
MAGICLAW_FEISHU_BASE_URL=https://open.feishu.cn
MAGICLAW_FEISHU_APP_ID=cli_xxx
MAGICLAW_FEISHU_APP_SECRET=replace_me
MAGICLAW_FEISHU_VERIFICATION_TOKEN=replace_me
MAGICLAW_FEISHU_SIGNING_SECRET=replace_me
MAGICLAW_FEISHU_RECEIVE_ID_TYPE=open_id

# Optional: multi-account Feishu config (JSON array)
# Channel IDs become feishu:<account_id> for non-default accounts.
# MAGICLAW_FEISHU_ACCOUNTS_JSON=[
#   {
#     "enabled": true,
#     "account_id": "tenant_a",
#     "base_url": "https://open.feishu.cn",
#     "app_id": "cli_xxx_a",
#     "app_secret": "secret_a",
#     "verification_token": "verify_a",
#     "signing_secret": "sign_a",
#     "receive_id_type": "open_id",
#     "timeout_ms": 15000
#   },
#   {
#     "enabled": true,
#     "account_id": "tenant_b",
#     "base_url": "https://open.feishu.cn",
#     "app_id": "cli_xxx_b",
#     "app_secret": "secret_b",
#     "verification_token": "verify_b",
#     "signing_secret": "sign_b",
#     "receive_id_type": "open_id",
#     "timeout_ms": 15000
#   }
# ]
