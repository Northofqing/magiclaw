# SQLite database shared by the daemon (token validation) and the auth/send CLI.
# Pin this to an absolute path so the daemon, `auth issue`, and `send` all agree.
# scripts/daemon-up.sh sets this automatically.
MAGICLAW_DB_PATH=/Users/zhangzhen/Desktop/magiclaw/data/magiclaw.db

# API auth for protected HTTP endpoints. Must be a token issued via
# `magiclaw auth issue` against MAGICLAW_DB_PATH (scripts/daemon-up.sh does this).
MAGICLAW_API_TOKEN=change_me

# Primary Feishu account (channel id: feishu when account_id=default)
FEISHU_ENABLED=true
FEISHU_ACCOUNT_ID=default
FEISHU_BASE_URL=https://open.feishu.cn
FEISHU_APP_ID=cli_xxx
FEISHU_APP_SECRET=replace_me
FEISHU_VERIFICATION_TOKEN=replace_me
FEISHU_SIGNING_SECRET=replace_me
FEISHU_RECEIVE_ID_TYPE=open_id

# Optional: multi-account Feishu config (JSON array)
# Channel IDs become feishu:<account_id> for non-default accounts.
# FEISHU_ACCOUNTS_JSON=[
#   {
#     "enabled": true,
#     "account_id": "tenant_a",
#     "base_url": "https://open.feishu.cn",
#     "app_id": "cli_xxx_a",
#     "app_secret": "secret_a",
#     "verification_token": "verify_a",
#     "signing_secret": "sign_a",
#     "receive_id_type": "open_id",
#     "timeout_ms": 15000
#   },
#   {
#     "enabled": true,
#     "account_id": "tenant_b",
#     "base_url": "https://open.feishu.cn",
#     "app_id": "cli_xxx_b",
#     "app_secret": "secret_b",
